{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/board/layout,_N_T_/board/review/layout,_N_T_/board/review/page,_N_T_/board/review"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/board/review/__PAGE__",
    "/board/review",
    "/board",
    "/_index",
    "/_head"
  ]
}