{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/board/layout,_N_T_/board/trpg/layout,_N_T_/board/trpg/page,_N_T_/board/trpg"
  },
  "segmentPaths": [
